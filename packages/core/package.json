{
  "name": "@htmless/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "HTMLess headless CMS core — API server, auth, content schemas, delivery, and preview",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk/client.js",
      "types": "./dist/sdk/client.d.ts"
    },
    "./blocks": {
      "import": "./dist/blocks/renderer-sdk.js",
      "types": "./dist/blocks/renderer-sdk.d.ts"
    }
  },
  "bin": {
    "htmless": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "prisma/",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "tsx tests/api.test.ts",
    "lint": "eslint src/",
    "prisma": "prisma"
  },
  "keywords": [
    "headless-cms",
    "cms",
    "content-management",
    "api",
    "rest",
    "graphql",
    "prisma",
    "express"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HTMLess-CMS/HTMLess"
  },
  "homepage": "https://htmless.com",
  "author": "HTMLess <hello@htmless.com>",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jose": "^6.0.11",
    "nanoid": "^5.1.5",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.2",
    "prisma": "^6.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
